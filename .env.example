DISCORD_TOKEN=
CLIENT_ID=
# Optional: registriert Slash Commands nur auf diesem Server, was beim Entwickeln schneller ist.
GUILD_ID=
# Discord-Rollenname oder Rollen-ID fuer Spielleitung/Admins. Leer = ManageGuild-Berechtigung reicht.
ADMIN_ROLE=
DATABASE_PATH=./data/amongus.sqlite
TASKS_PATH=./data/tasks.json
KILL_COOLDOWN_SECONDS=30
DEFAULT_DISCUSSION_TIME_MINUTES=3
DEFAULT_VOTING_TIME_MINUTES=2
EMERGENCY_COOLDOWN_SECONDS=300
DEBUG_MODE=false
LOG_LEVEL=info
DEBUG_MAX_GHOST_PLAYERS=15
# Optional: Pfad zu einem zusaetzlichen Root-CA-Zertifikat, z.B. C:\Pfad\zum\schule.pem
EXTRA_CA_CERT_PATH=
# Optional: nur mit false deaktivieren. Standard ist aktiv.
WEB_PANEL_ENABLED=true
WEB_PANEL_PORT=3000
ADMIN_PANEL_ENABLED=false
ADMIN_PANEL_KEY=
